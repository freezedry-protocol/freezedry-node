# Freeze Dry Node — Environment Configuration
# Copy to .env and fill in your values
#
# This node can run as a reader (indexes chain, serves artwork),
# a writer (inscribes memos to Solana), or both.
#
# IMPORTANT: Read docs/rpc-budget.md before changing polling/fill settings.
# Wrong defaults can burn your entire Helius plan in hours.

# ─── Helius Plan (auto-configures everything) ───
# Set ONE of: free | developer | business | geyser
# This auto-sets CREDIT_BUDGET, MARKETPLACE_ENABLED, and safe defaults.
# Individual env vars below still override if you need fine-grained control.
# Omit to use manual configuration (defaults are safe).
# HELIUS_PLAN=free

# ─── Data Directory ───
# Store DB + blobs OUTSIDE the git repo so git operations never touch your data.
# Recommended: /var/lib/freezedry-node (create with: sudo mkdir -p /var/lib/freezedry-node && sudo chown $USER /var/lib/freezedry-node)
# If unset, defaults to ./db/ inside the repo (NOT recommended for production).
DATA_DIR=/var/lib/freezedry-node

# ─── Required ───

# Helius RPC key (get a free key at https://helius.dev)
# Leave blank to run in gossip-only mode (recommended for community nodes)
HELIUS_API_KEY=

# ─── Role ───

# "reader" = index chain + serve artwork (default behavior)
# "writer" = accept inscription jobs from coordinator
# "both"   = reader + writer (default)
ROLE=both

# ─── RPC Tier Presets ───
# These are set by the setup wizard based on your Helius plan tier.
#
#   Tier             DIRECT  MARKETPLACE  CAPACITY  POLL_INTERVAL  CREDIT_BUDGET
#   Public (free)    5       5            1         3600000        100000
#   Developer        15      5            2         3600000        1000000
#   Business         50      20           4         3600000        5000000
#   Geyser           100     50           8         3600000        0 (unlimited)

# ── Blob Size Limits ──
# Direct: user pre-pays SOL to hot wallet, safe to accept larger files.
# Marketplace: node fronts TX fees from own wallet, gets reimbursed after attestation.
# MAX_BLOB_MB is the fallback if split vars not set.
# MAX_BLOB_MB=15
# MAX_DIRECT_BLOB_MB=15
# MAX_MARKETPLACE_BLOB_MB=5

# Max concurrent inscription jobs
# CAPACITY=1

# ─── Identity & Wallet (Two-Wallet System) ───
# Each node has two keypairs: identity (peer auth) + hot wallet (TX signing).
# Both are Solana keypair JSON arrays [1,2,...,64].
# setup.sh generates these automatically.

# Identity key — peer authentication, reputation, display name. Never needs SOL.
# IDENTITY_KEYPAIR=

# Hot wallet — signs memo TXs, pays fees, receives escrow earnings. Needs SOL for writer role.
# HOT_WALLET_KEYPAIR=

# Legacy: WALLET_KEYPAIR works for both if the separate keys aren't set.
# WALLET_KEYPAIR=

# Shared API key — must match the key configured on the coordinator (freezedry.art)
# API_KEY=

# ─── Discovery (Reader) ───

# Wallet to scan for FREEZEDRY: pointer memos.
# Default: official Freeze Dry inscriber — your node auto-indexes all public content.
# This is a PUBLIC read-only lookup address (not a secret).
# Public wallet to scan for FREEZEDRY: pointer memos (read-only lookup, not a secret)
SERVER_WALLET=

# Registry URL for startup backfill (seeds existing artworks on first run)
REGISTRY_URL=https://freezedry.art/api/registry

# Coordinator URL for auto-registration + peer discovery
COORDINATOR_URL=https://freezedry.art

# ─── RPC Budget Protection ───
# These defaults are SAFE. Do not change unless you understand the credit cost.
# See docs/rpc-budget.md for full explanation.

# Monthly credit budget (circuit breaker trips at 80% of this)
# Free plan: 100000, Developer: 1000000, Business: 5000000, Geyser: 0
CREDIT_BUDGET=100000

# Chain fill: reconstruct blobs from on-chain memos (EXPENSIVE — ~5,000 credits/artwork)
# Default OFF. Blobs come from peers + gossip + webhooks instead.
# Only enable for emergency recovery: CHAIN_FILL=true + MAX_FILL_PER_CYCLE=1
# CHAIN_FILL=false
MAX_FILL_PER_CYCLE=0

# Give up on artworks that fail peer fill after this many attempts
MAX_FILL_ATTEMPTS=5

# Scan interval: how often to check chain for new pointers (safety net)
# With webhooks active, this is redundant — set high.
# 3600000 = 1hr (recommended), 900000 = 15min (backup), 120000 = 2min (NOT recommended)
POLL_INTERVAL=3600000

# Job marketplace poll interval (claimer + attester)
# Tier-appropriate: Free plan = 300000 (5min), Developer = 60000 (60s), Business = 30000 (30s)
# Lower = faster job pickup but more credits. See docs/node-tiers.md for budget math.
CLAIM_POLL_INTERVAL=300000

# First Freeze Dry inscription — prevents scanning older than this on first run.
# Without this, a new node scans the entire wallet history (~30,000 credits).
# Find by searching your SERVER_WALLET's transaction history for the first FREEZEDRY: pointer memo
GENESIS_SIG=

# ─── Optional ───

# Webhook/ingest auth secret — REQUIRED for write endpoints (/ingest, /webhook/helius)
# Without this, those endpoints return 403 (read-only mode).
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=

# Custom RPC URL (overrides default Helius RPC)
# HELIUS_RPC_URL=

# Blob access: "false" (default) = only active peers can download blobs.
# BLOB_PUBLIC=false

PORT=3100
NODE_ID=my-freezedry-node

# ─── Peer Network ───

# Your node's reachable address — set ONE of these:
# Option A: Domain (requires HTTPS reverse proxy + nginx forwarding X-FD-* headers)
# NODE_URL=https://node.yourdomain.com
# Option B: IP:port (no domain needed — simplest for home/VPS nodes)
# NODE_ENDPOINT=203.0.113.5:3100

# Bootstrap peers — optional, comma-separated URLs
# Peers are discovered automatically via the coordinator. Add known peers here for faster bootstrap.
# PEER_NODES=https://peer1.example.com,https://peer2.example.com

# ─── Dual RPC (redundancy) ───
# Simplest setup: set RPC_BACKUP_URL and ALL pools (jobs, indexer, send) use it.
# RPC_BACKUP_URL=https://your-backup-rpc.com
# RPC_BACKUP_URL_2=https://another-backup.com
#
# Strategy: "round-robin" (default) or "failover" (primary + fallback on error)
# RPC_STRATEGY=round-robin
#
# Advanced: per-pool overrides (only if you need different backup RPCs per function)
# JOBS_RPC_URL_2=       # marketplace polling
# HELIUS_RPC_URL_2=     # chain scanning
# SEND_RPC_URL_2=       # transaction submission (supports _2 through _5)

# ─── Writer: Additional RPC fallbacks (legacy) ───
# SHYFT_API_KEY=
# CHAINSTACK_SOLANA_URL=

# ─── Blob Cache (pruning — reader/both nodes) ───
# Prune stale blobs to manage disk usage. LRU eviction with tombstones.
# Both values must be > 0 for pruning to activate.
# BLOB_CACHE_DAYS=7       # evict blobs not accessed in N days
# BLOB_CACHE_MAX_MB=500   # evict when total cache exceeds this size (prunes to 90%)

# ─── Jobs Marketplace ───
# MARKETPLACE_ENABLED=true
# JOBS_RPC_URL=  # defaults to same as Helius RPC
JOBS_PROGRAM_ID=AmqBYKYCqpmKoFcgvripCQ3bJC2d8ygWWhcoHtmTvvzx

# Node operation mode:
#   "dedicated" — only claim jobs assigned to this node (your own site traffic).
#                 If at capacity, jobs wait for exclusive window to expire → open market.
#   "open"      — claim any available job. Assigned jobs always get priority. (default)
# NODE_MODE=open

# Reserve capacity slots for assigned jobs (only applies in "open" mode).
# e.g. CAPACITY=3, RESERVED_SLOTS=1 → max 2 open-market jobs, 1 slot always free for assigned work.
# RESERVED_SLOTS=0

# ─── Throughput Optimizations ───
# See docs/throughput-optimizations.md for full details.
# Default behavior is unchanged — all optimizations are opt-in.

# Writer pipeline tuning
# WORKERS=1                    # parallel job workers (1 for Dev, scale with RPC tier)
# SEND_CONCURRENCY=6           # TXs per batch per worker (default 6)
# BATCH_DELAY_MS=400           # ms between batches
# CONFIRM_WAIT_MS=2500         # ms before first confirm check (ignored when USE_WEBSOCKET=true)
# FEE_REFRESH_MS=60000         # refresh priority fee every 60s (prevents stale fees on long jobs)
# MULTI_JOB_CONCURRENCY=0      # 0=auto, >0=override per-job concurrency for higher RPC tiers
# RPS_LIMIT=50                 # requests/sec cap (match your Helius plan: 10/50/200/500)

# WebSocket confirms — DEFAULT ON (4.6x speedup, 0 credits, 100% success rate)
# Auto-derives WS URL from HELIUS_API_KEY. No extra config needed.
# Set to false only if you have WS connectivity issues.
USE_WEBSOCKET=true
# HELIUS_WS_URL=               # custom WS URL (only if using non-Helius RPC)
# WS_CONFIRM_TIMEOUT_MS=10000  # fall back to polling after this

# Jito bundles — guaranteed block inclusion (5x speedup, tiny tip cost)
# Mainnet only. No devnet support.
# JITO_ENABLED=false
# JITO_TIP_LAMPORTS=10000      # tip per bundle (0.00001 SOL = ~$0.001)
# JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# ─── POD (Proof of Delivery) ───
# SHYFT_API_KEY=
# CHAINSTACK_SOLANA_URL=
# POD_SIGNING_KEY=
# POD_CDN_PUBKEY=
# POD_PROGRAM_ID=
# POD_NETWORK=devnet
